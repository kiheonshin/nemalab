{
  "name": "nema-lab",
  "private": true,
  "version": "2.1.0",
  "description": "Interactive sensorimotor and neural visualization demo for C. elegans behavior.",
  "author": "Kiheon Shin",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "cap:copy": "npm run build && cap copy",
    "cap:sync": "npm run build && cap sync",
    "ios:add": "cap add ios",
    "ios:sync": "npm run build && cap sync ios",
    "ios:open": "cap open ios",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:start": "npm run build && electron .",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:dist": "npm run build && electron-builder",
    "electron:mac:dist": "npm run build && electron-builder --mac dmg zip mas",
    "brand:assets": "python scripts/generate_brand_assets.py",
    "atlas:celegans": "python scripts/generate_celegans_atlas.py",
    "atlas:connectome-b": "node scripts/generate_connectome_b_data.mjs",
    "serve:dist": "node scripts/serve-dist.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.2.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "i18next": "^23.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.0",
    "react-router-dom": "^6.28.0",
    "three": "^0.183.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "build": {
    "appId": "com.kiheonshin.nemalab",
    "productName": "Nema Lab",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        "dmg",
        "zip",
        "mas"
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "gatekeeperAssess": false,
      "hardenedRuntime": true
    },
    "mas": {
      "category": "public.app-category.education",
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist"
    },
    "win": {
      "icon": "public/android-chrome-512x512.png",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
